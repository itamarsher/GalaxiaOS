# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=abos
POSTGRES_PASSWORD=abos
POSTGRES_DB=abos
# Async URL used by the app (asyncpg). docker-compose sets host=postgres.
ABOS_DATABASE_URL=postgresql+asyncpg://abos:abos@localhost:5432/abos

# ── Redis (arq queue + breaker counters) ────────────────────────────────────
ABOS_REDIS_URL=redis://localhost:6379/0

# ── Deployment topology ─────────────────────────────────────────────────────
# Run the arq worker inside the API process instead of as a separate service.
# Leave false in production (scale API and worker independently); set true to
# fit the whole app on a single host, e.g. a free-tier web instance.
ABOS_RUN_WORKER_IN_PROCESS=false

# ── Auth ────────────────────────────────────────────────────────────────────
ABOS_JWT_SECRET=change-me-in-production-use-a-long-random-string
ABOS_JWT_EXPIRE_MINUTES=10080

# ── Envelope encryption master key (BYOK key wrapping) ──────────────────────
# 32-byte key, base64url-encoded. Generate with:
#   python -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ABOS_MASTER_KEY=

# ── Managed mode (hosted "no keys needed" tier) ─────────────────────────────
# Off by default → self-hosting stays strictly BYOK (each founder brings their
# own key; nobody's key is shared). Turn this on for a HOSTED deployment so a
# founder who stores NO key still launches: the platform supplies a shared LLM
# key (and the platform-configured read-only capabilities — web search, media),
# metered against a per-founder free allowance that can convert to paid managed.
# A founder's own stored key always wins, is never metered against the allowance,
# and lifts every managed limit.
ABOS_MANAGED_MODE_ENABLED=false
# The shared LLM the platform funds. Provider is explicit (must be one of the
# supported providers: anthropic | openrouter | groq | together | openai_compat).
# Defaults to openrouter — a subsidized free tier wants the cheapest capable
# tokens, and OSS models via OpenRouter are typically far cheaper per token than
# Claude. The key is a deployment SECRET — never stored as a company key, never
# returned by any API. Set BOTH when enabling managed mode (empty key => managed
# LLM is unavailable and keyless companies can't launch).
ABOS_PLATFORM_LLM_PROVIDER=openrouter
ABOS_PLATFORM_LLM_API_KEY=
# Per-founder LIFETIME free allowance of platform-funded spend (cents), pooled
# across all their companies. Crossing it stops managed capabilities until they
# add their own key or upgrade to paid managed. Default $2.00.
ABOS_PLATFORM_FREE_TIER_CENTS=200
# Abuse backstop: max platform-funded spend per founder per UTC day (cents). 0
# disables the daily guard.
ABOS_PLATFORM_DAILY_CAP_CENTS=100
# Paid managed tier (usage-based billing of platform-funded spend). Empty => the
# upgrade flow reports it's not configured (free tier still works; over-cap
# founders are asked to bring their own key). Reuses ABOS_STRIPE_SECRET_KEY for
# the API call and ABOS_STRIPE_WEBHOOK_SECRET to verify the checkout webhook.
ABOS_STRIPE_MANAGED_PRICE_ID=
# Markup on platform-funded cost when billing paid managed usage (1.0 = passthrough).
ABOS_MANAGED_BILLING_MARKUP=1.3

# ── LLM provider (BYOK — the key your agents think with) ────────────────────
# The LLM provider is NOT an env var: each founder stores their own key in the
# app (Settings), envelope-encrypted with ABOS_MASTER_KEY. The provider is
# chosen by which key they store. Supported providers:
#   anthropic                       — Claude (sk-ant-…)
#   openrouter | groq | together    — open-source models (Llama 3.3, DeepSeek R1,
#                                     Qwen, gpt-oss, …) over hosted OpenAI-compatible
#                                     APIs. BYOK, no infra, typically far cheaper
#                                     per token than Claude. URLs are baked in.
#
# Self-hosted open-source models: to point the fleet at your OWN OpenAI-compatible
# server (vLLM / Ollama / TGI, on an external GPU host — Render has no GPU tier),
# set the base URL and the per-tier model slugs it serves. Empty base URL => the
# "openai_compat" provider is not offered. The founder then stores that server's
# token (or any placeholder) under the "openai_compat" provider in Settings.
ABOS_OPENAI_COMPAT_BASE_URL=
ABOS_OPENAI_COMPAT_MODEL_CHEAP=
ABOS_OPENAI_COMPAT_MODEL_PLANNER=
ABOS_OPENAI_COMPAT_MODEL_STRATEGIC=

# ── Runtime safety caps (circuit breakers) ──────────────────────────────────
ABOS_MAX_TASK_DEPTH=4
ABOS_MAX_TASKS_PER_RUN=200
ABOS_MAX_TASKS_PER_AGENT_WINDOW=30
ABOS_MAX_LOOP_SIGNATURE_REPEATS=3
ABOS_MAX_STEPS_PER_TASK=12

# ── Domain registrar (external integration) ────────────────────────────────
# simulated (default; NOT connected — register_domain reports the capability is
# unsupported and the agent can request it) | rdap (real availability, simulated
# purchase) | namecheap (real availability + REAL purchase — verify in sandbox first)
# | card_checkout (real availability + a REAL Stripe charge against the agent's
# Stripe Link credential; needs ABOS_PAYMENT_WALLET=stripe_link below)
ABOS_DOMAIN_REGISTRAR=simulated
ABOS_RDAP_TIMEOUT_SECONDS=4.0
# Only needed when ABOS_DOMAIN_REGISTRAR=namecheap. Live by default; set true for
# the Namecheap sandbox.
ABOS_NAMECHEAP_SANDBOX=false
ABOS_NAMECHEAP_API_USER=
ABOS_NAMECHEAP_API_KEY=
ABOS_NAMECHEAP_USERNAME=
ABOS_NAMECHEAP_CLIENT_IP=
# Registrant contact as JSON, e.g.:
# ABOS_NAMECHEAP_CONTACT={"FirstName":"Ada","LastName":"Lovelace","Address1":"1 St","City":"London","StateProvince":"LDN","PostalCode":"E1","Country":"GB","Phone":"+44.2000000000","EmailAddress":"ada@example.com"}
ABOS_NAMECHEAP_CONTACT=
# Fail a registration before the irreversible create when the Namecheap balance
# can't cover it (clear "top up" error instead of a vendor failure mid-purchase).
ABOS_NAMECHEAP_PRECHECK_BALANCE=true

# ── Payment wallet: real agent access to external spend (Stripe Link) ───────
# none (default; no wallet wired — capabilities needing real spend report
# unsupported) | stripe_link (real Stripe Link agent wallet: the agent mints a
# scoped, single-purchase Shared Payment Token a seller then charges).
ABOS_PAYMENT_WALLET=none
# Test or live secret key — used as-is. A live key (sk_live_…) moves REAL money;
# spend is bounded by the company budget (CostMeter) and Issuing spending_controls.
ABOS_STRIPE_SECRET_KEY=
ABOS_STRIPE_API_VERSION=2026-04-22.preview
ABOS_STRIPE_TIMEOUT_SECONDS=20.0
ABOS_STRIPE_CURRENCY=usd
# Only needed when ABOS_PAYMENT_WALLET=stripe_link. The PaymentMethod is the
# wallet-backed credential issued via Stripe's link-cli (link-cli auth login →
# payment-methods list); the network business profile scopes the SPT to a seller.
ABOS_STRIPE_LINK_NETWORK_BUSINESS_PROFILE=
ABOS_STRIPE_LINK_PAYMENT_METHOD=
ABOS_STRIPE_LINK_RETURN_URL=
ABOS_STRIPE_LINK_TOKEN_TTL_SECONDS=600
# Only needed when ABOS_DOMAIN_REGISTRAR=card_checkout:
ABOS_CARD_CHECKOUT_MERCHANT_NAME=ABOS Domains
ABOS_CARD_CHECKOUT_MERCHANT_URL=

# ── Stripe Issuing: a budget-controlled virtual card to fund external accounts ─
# The Base44-style path: an Issuing card tops up the registrar balance (one-time
# or periodic), then the agent buys domains via the namecheap API (pure API,
# CostMeter-metered). Authorizations are gated programmatically — no human signs
# off each charge — by the real-time-auth webhook at POST /webhooks/stripe/issuing,
# which approves only within the company's remaining budget. Reuses the
# ABOS_STRIPE_* keys above (test-mode first; live keys refused until you opt in).
ABOS_STRIPE_ISSUING_CARDHOLDER=        # existing Stripe cardholder id (ich_…)
ABOS_STRIPE_ISSUING_MONTHLY_LIMIT_CENTS=50000  # hard per-card backstop cap
ABOS_STRIPE_WEBHOOK_SECRET=            # whsec_… — verifies the Issuing auth webhook

# Web search seam: simulated (default; NOT connected — web_search reports the
# capability is unsupported) | tavily (real; needs a key)
ABOS_WEB_SEARCH_PROVIDER=simulated
ABOS_WEB_SEARCH_MAX_RESULTS=5
ABOS_WEB_SEARCH_TIMEOUT_SECONDS=10.0
# Only needed when ABOS_WEB_SEARCH_PROVIDER=tavily:
ABOS_TAVILY_API_KEY=
ABOS_TAVILY_SEARCH_DEPTH=basic

# Brand media-generation seam (the design / graphic-designer agent): simulated
# (default; NOT connected — generate_image/generate_video report the capability is
# unsupported) | google (real; Nano Banana image + Veo video via the Generative
# Language API). A per-company BYO key (stored under the "nano_banana" provider slot)
# overrides ABOS_GOOGLE_API_KEY. Generation is metered through the CostMeter and the
# finished asset is filed into the company's Drive store.
ABOS_MEDIA_GEN_PROVIDER=simulated
# Only needed when ABOS_MEDIA_GEN_PROVIDER=google:
ABOS_GOOGLE_API_KEY=
ABOS_NANO_BANANA_IMAGE_MODEL=gemini-2.5-flash-image
ABOS_NANO_BANANA_VIDEO_MODEL=veo-3.0-generate-001
ABOS_MEDIA_IMAGE_COST_CENTS=4
ABOS_MEDIA_VIDEO_COST_CENTS=50

# Email seam: simulated (default; NOT connected — send_email reports the
# capability is unsupported)
# | smtp   (real; vendor-agnostic SMTP)
# | resend (real; Resend API — generous free tier + custom domains)
ABOS_EMAIL_PROVIDER=simulated
# Sender address. With resend this must be on a domain you've verified in Resend
# (add the SPF/DKIM DNS records it gives you), e.g. hello@yourstartup.com.
ABOS_EMAIL_FROM=
# Only needed when ABOS_EMAIL_PROVIDER=smtp:
ABOS_SMTP_HOST=
ABOS_SMTP_PORT=587
ABOS_SMTP_USERNAME=
ABOS_SMTP_PASSWORD=
ABOS_SMTP_USE_TLS=true
# Only needed when ABOS_EMAIL_PROVIDER=resend (free tier: 3,000/mo, 100/day):
ABOS_RESEND_API_KEY=

# ── Company Memory embeddings ───────────────────────────────────────────────
# How memory text is turned into the vector used for similarity recall.
#   local (default)  — real neural model via fastembed (ONNX/CPU): no per-call
#                      cost and no network once the model is cached. Degrades to
#                      hashing if fastembed/the model can't load (e.g. low memory).
#   hashing          — dependency-free lexical embedder (no model, fully offline).
#   openai           — real semantic embeddings via the OpenAI REST API
#                      (needs ABOS_OPENAI_API_KEY).
# Switching on a populated DB only re-embeds new writes; backfill existing rows
# to re-rank them.
ABOS_EMBEDDINGS_PROVIDER=local
ABOS_LOCAL_EMBEDDINGS_MODEL=BAAI/bge-small-en-v1.5
ABOS_EMBEDDINGS_MODEL=text-embedding-3-small
ABOS_OPENAI_API_KEY=
# Recall blends similarity with recency (a memory's weight halves every N days):
ABOS_MEMORY_RECENCY_HALF_LIFE_DAYS=30

# ── File store seam (company's external file provider) ──────────────────────
# Agents file deliverables, financial records, data-room docs, brand guidelines
# and received files into the founder's Google Drive under
# <root>/<company>/<category>/…. With no Drive connected, the file tools report
# the capability is unsupported (never faked).
# This only names the top-level folder created in the founder's Drive:
ABOS_GDRIVE_ROOT_FOLDER=.galaxia
#
# Google OAuth: ONE Google Cloud OAuth client for the whole deployment powers
# THREE things — "Sign in with Google" (default sign-up/login), the account-wide
# Drive grant (connect once per user; every business files into that Drive), and
# the legacy per-company Drive connect. Founders never touch the Cloud Console.
# Scopes requested: `openid email profile` for login (no verification needed) and
# `drive.file` for Drive (app-created files only — least privilege).
# On the OAuth client, add BOTH Authorized redirect URIs:
#   <ABOS_PUBLIC_API_BASE_URL>/auth/google/callback              (login + account-wide Drive)
#   <ABOS_PUBLIC_API_BASE_URL>/integrations/google-drive/callback (legacy per-company Drive)
# Leave these blank to disable Google sign-in and Drive connect entirely (email/
# password sign-up still works as a fallback).
ABOS_GOOGLE_OAUTH_CLIENT_ID=
ABOS_GOOGLE_OAUTH_CLIENT_SECRET=
# Public URL of the API (where Google redirects back) and the web app (where the
# founder lands afterwards, on the Settings page). Set these per deployment, e.g.
# https://your-api.example.com / https://your-app.example.com. A scheme-less host
# or a trailing slash is tolerated (normalized to https://…, no trailing slash).
# On Render these are auto-wired from the service hosts (see render.yaml), so the
# domain lives in one place — you only set them here for non-Render deployments.
ABOS_PUBLIC_API_BASE_URL=
ABOS_WEB_BASE_URL=

# ── Observability & rate limiting ───────────────────────────────────────────
ABOS_LOG_LEVEL=INFO
ABOS_LOG_JSON=true
ABOS_RATE_LIMIT_ENABLED=true
ABOS_RATE_LIMIT_PER_MINUTE=120
# memory (single process) | redis (multi-process / production)
ABOS_RATE_LIMIT_BACKEND=memory

# ── Error monitoring → auto-fix issues ──────────────────────────────────────
# When enabled, any code error (a logged traceback in the API or worker) and any
# Render platform failure (failed deploy / suspended service) is escalated to a
# deduplicated tracker issue that the Claude Code auto-fix pipeline can pick up.
# No-op until a GitHub token + repo are set; the Render scan also needs a key.
ABOS_ERROR_MONITOR_ENABLED=false
# owner/repo to file issues against, plus a token with 'issues' write scope.
ABOS_GITHUB_REPO=
ABOS_GITHUB_TOKEN=
# Labels applied to filed issues. The default routes through issue-triage (which
# adds 'claude-implement'); set to 'claude-implement' to auto-fix directly.
ABOS_ERROR_MONITOR_LABELS=bug,auto-detected
# Read-only Render API key for the platform scan. The owner id is optional — it
# is auto-derived from the key; only set it to disambiguate a multi-owner key.
ABOS_RENDER_API_KEY=
ABOS_RENDER_OWNER_ID=

# Browser origins allowed to call the API (CORS). Comma-separated; "*" allows
# any origin. In production set this to the web origin, e.g.
# ABOS_CORS_ALLOW_ORIGINS=https://abos-web.onrender.com
ABOS_CORS_ALLOW_ORIGINS=*

# ── Connected agents (RFC 0001) ───────────────────────────────────────────────
# Run a function on an EXTERNAL worker instead of the native in-process loop. Two
# postures, both over the Business-Function surface; both are OFF until configured.
#
# PUSH — a managed OpenClaw Gateway Galaxia invokes per initiative. Set the base URL
# to bind the push worker; empty ⇒ an 'external' agent reports "no runtime connected".
# Model empty ⇒ route by function ("openclaw/<function>").
ABOS_OPENCLAW_BASE_URL=
ABOS_OPENCLAW_API_KEY=
ABOS_OPENCLAW_MODEL=
ABOS_OPENCLAW_TIMEOUT_SECONDS=120
# How long a claimed initiative's lease lasts before the reaper reoffers it (pull).
ABOS_INITIATIVE_LEASE_SECONDS=900
#
# PULL — an external agent connects IN over MCP (Org → agent → "Connect an external
# agent" mints a per-function bearer token). This secret signs those tokens; empty
# ⇒ the pull transport is off and every token is rejected. Use a long random string.
ABOS_FUNCTION_CONNECTION_SECRET=

# ── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
